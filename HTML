<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pong Game</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>Pong Game</h1>
        <div class="scoreboard">
            <div class="score-section">
                <p class="label">Player</p>
                <p class="score" id="playerScore">0</p>
            </div>
            <div class="score-section">
                <p class="label">Computer</p>
                <p class="score" id="computerScore">0</p>
            </div>
        </div>
        
        <div class="game-info">
            <p>Use <strong>Mouse</strong> or <strong>Arrow Keys (↑/↓)</strong> to move left paddle</p>
        </div>
        
        <canvas id="gameCanvas" width="800" height="400"></canvas>
        
        <button id="resetBtn" class="reset-btn">Reset Game</button>
    </div>
    
    <script src="script.js"></script>
</body>
</html>
